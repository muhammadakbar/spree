# Ruby 3.2.2 use karein
FROM ruby:3.2.2

# System dependencies install karein
RUN apt-get update -qq && apt-get install -y \
    build-essential \
    libpq-dev \
    nodejs \
    npm \
    imagemagick \
    yarn \
    git

# Work directory set karein
WORKDIR /app

# Sab se pehle saara code copy karein taake common_spree_dependencies.rb mil jaye
COPY . .

# Bundler install karein aur platform fix karein
RUN gem install bundler:2.4.10
RUN bundle lock --add-platform x86_64-linux
RUN bundle install

# Assets precompile (Production mode)
ENV RAILS_ENV=production
# Spree/Rails ko database connection chahiye hota hai precompile ke liye
# Agar yahan error aaye toh is line ko comment kar dena
RUN bundle exec rake assets:precompile || true

# Port expose
EXPOSE 3000

# Start command
CMD ["bundle", "exec", "rails", "s", "-b", "0.0.0.0", "-p", "3000"]
